# Template for .env file
# HOW TO USE:
# ➡️cp .env.example .env.dev    - fill for local development
# ➡️cp .env.example .env.prod   - fill with real production values
# NEVER commit .env.dev or .env.prod to your github, they are gitignored.

# IMAGE CONFIG
DOCKERHUB_ACCOUNT=ripanbaidya
APP_NAME=lunecare
IMAGE_TAG=1.0.0

# Spring Profile
# Controls which application-{profile}.yml is loaded from config repo.
# Values: dev | docker | prod
SPRING_PROFILES_ACTIVE=dev

# Config Server
# All microservices bootstrap from this URL to fetch their configuration.
CONFIG_SERVER_URL=http://config-server:8888

# Git repository backing Spring Cloud Config Server.
# Dev  👉 public repo, GIT_USERNAME and GIT_PASSWORD are not required.
# Prod 👉 private repo, set GIT_USERNAME + GIT_PASSWORD (GitHub PAT).
GIT_URI=https://github.com/ripanbaidya/lune-care-config.git
GIT_USERNAME=your-github-username
GIT_PASSWORD=personal-access-token-not-actual-github-password

# Symmetric encryption key for Spring Cloud Config.
# ONLY config-server uses this to decrypt {cipher} values from the config repo.
# Individual microservices do NOT need it — config-server decrypts before serving.
# This must be the SAME key you used when encrypting secrets via POST /encrypt.
# While setting up the Key make sure enclosed key within single quote as you key contain several characters
ENCRYPT_KEY=

# Eureka Server - Service Discovery
EUREKA_HOSTNAME=eureka-server
EUREKA_DEFAULT_ZONE=http://eureka-server:8761/eureka

# RabbitMQ
# Used for Spring Cloud Bus (live config refresh) and all async domain events.
# Dev  👉local container, default guest credentials are fine.
# Prod 👉managed broker: CloudAMQP / Amazon MQ / etc.
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# Redis
# Used by api-gateway (rate limiting), auth (token blacklist), appointment (cache).
# Dev  👉local container, no password needed.
# Prod 👉managed Redis: ElastiCache / Upstash / Redis Cloud / etc.
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# PostgreSQL — DB container bootstrap only
# These credentials are used by Docker Compose to initialise each Postgres
# container (POSTGRES_USER / POSTGRES_PASSWORD env vars on the image).
# Spring services get their JDBC URLs from config-server as {cipher} values -
# NOT from these variables.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# MongoDB - DB container bootstrap only
# Same principle as above — only used by Docker Compose container init.
# Spring services get their MongoDB URIs from config-server.
MONGO_USERNAME=mongouser
MONGO_PASSWORD=mongopass

# JWT — Auth Service
# Milliseconds. Defaults are 1 hour access / 7 day refresh.
JWT_ACCESS_TOKEN_EXPIRY=3600000
JWT_REFRESH_TOKEN_EXPIRY=604800000

# OBSERVABILITY — Prometheus + Grafana (not wired yet)
# Uncomment when activating the observability stack.
# GRAFANA_ADMIN_USER=admin
# GRAFANA_ADMIN_PASSWORD=changeme
